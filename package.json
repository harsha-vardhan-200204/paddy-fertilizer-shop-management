{
  "name": "paddy-fertilizer-shop-management",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Full-stack Paddy Fertilizer Shop Management System for GST billing, inventory, purchases, customers, suppliers, and reports.",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server.js",
    "client:dev": "vite --configLoader native --host 0.0.0.0",
    "start": "node server.js",
    "build": "vite build --configLoader native",
    "preview": "vite preview --configLoader native --host 0.0.0.0",
    "seed": "node server/scripts/seed.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "bcryptjs": "^3.0.2",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "vite": "^6.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "nodemon": "^3.1.7",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
